PORT=3001
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
FRONTEND_ORIGIN=http://localhost:5173
ADMIN_API_TOKEN=change_me_in_production

# Producción:
# - DATABASE_URL debe venir de Supabase/Neon/Render Postgres.
# - ADMIN_API_TOKEN debe ser largo, aleatorio y secreto.
# - FRONTEND_ORIGIN debe ser la URL real del frontend en Cloudflare Pages.
